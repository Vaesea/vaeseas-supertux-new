(supertux-level
  (version 3)
  (name (_ "Nolok Is Here"))
  (author "Sophie \"Vaesea\" Ball")
  (license "CC-BY-SA 4.0 International")
  (allow-item-pocket "inherit")
  (icon "")
  (icon-locked "")
  (statistics
    (enable-coins #t)
    (enable-secrets #t)
  )
  (sector
    (name "main")
    (init-script "Tux.deactivate();
Nolok.set_action(\"stand-left\");
Tux.walk(140);
Text.set_font(\"normal\");
Text.set_text(\"Tux had reached the peak of the mountain, now all he needed to do was find Nolok.\");
Text.fade_in(1);
wait(4);
Text.fade_out(1);")
    (ambient-light
      (color 1 1 1)
    )
    (background
      (scroll-offset-y 200)
      (color 1 1 1)
      (speed 0.1)
      (image-top "/images/background/bluemountain-top.png")
      (image "/images/background/bluemountain-middle.png")
      (image-bottom "/images/background/bluemountain-bottom.png")
    )
    (camera
      (name "Camera")
      (mode "normal")
    )
    (music
      (file "/music/greatgigantic.music")
    )
    (particles-clouds
    )
    (particles-clouds
    )
    (particles-snow
    )
    (particles-snow
    )
    (particles-snow
    )
    (scriptedobject
      (z-pos 50)
      (name "Nolok")
      (sprite "/images/creatures/nolok/nolok.sprite")
      (x 1888)
      (y 800)
    )
    (scripttrigger
      (oneshot #t)
      (script "Tux.walk(0);
wait(0.5);
Text.set_font(\"normal\");
Text.set_text(\"Nolok: Ah, Tux. I was waiting for you.\");
Text.fade_in(1);
wait(3);
Text.fade_out(1);
wait(1.5);
Text.set_text(\"Behind me is the peak of the mountain. It has 5 keys, getting all of them will let you enter my castle.\");
Text.fade_in(1);
wait(5);
Text.fade_out(1);
wait(1.5);
Nolok.set_velocity(180, 0);
Nolok.set_action(\"walk-right\");
wait(1);
Nolok.set_velocity(435, -1024);
Nolok.set_action(\"jump-right\");
wait(1);
Tux.walk(140);
Effect.fade_out(2);
wait(3);
Level.finish(true);")
      (button #f)
      (width 32)
      (height 32)
      (x 1504)
      (y 832)
    )
    (spawnpoint
      (name "main")
      (x 64)
      (y 800)
    )
