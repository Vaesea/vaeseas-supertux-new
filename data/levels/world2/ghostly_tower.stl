    (scripttrigger
      (oneshot #t)
      (script "Tux.deactivate();
play_music(\"\");
wait(0.5);
Text.set_text(\"Tux had reached the end of the tower...\");
Text.set_font(\"normal\");
Text.fade_in(1);
wait(3);
Text.fade_out(1);
wait(1.5);
Tux.walk(140);")
      (button #f)
      (width 32)
      (height 256)
      (x 3744)
      (y 4288)
    )
    (scripttrigger
      (script "Tux.walk(0);
Text.set_font(\"normal\");
wait(0.5);
Text.set_text(\"He found a letter from Penny, and when he read it, he was angry.\");
Text.fade_in(1);
wait(4);
Text.fade_out(1);
wait(1.5);
Text.set_text(\"The letter said that Nolok had moved to a Tropical Island!\");
Text.fade_in(1);
wait(4);
Text.fade_out(1);
wait(1.5);
Text.set_text(\"Tux had to find this Tropical Island and defeat Nolok.\");
Text.fade_in(1);
wait(4);
Text.fade_out(1);
wait(1.5);
Tux.walk(320);
wait(2);
Effect.fade_out(2);
wait(3);
Level.finish(true);")
