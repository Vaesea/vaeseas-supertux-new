      (script "if(! (\"hint_displayed\" in this) ){
	Tux.deactivate ();
	Tux.set_visible( false);
	Camera.set_mode( \"manual\" );
	Effect.sixteen_to_nine(0);
	Camera.scroll_to( 2000, 800, 5);
	wait( 6 );
	Camera.set_mode( \"normal\" );
 	Effect.four_to_three( 0 );
	Level.spawn( \"main\", \"sign\" )
	Tux.set_visible( true );
	Tux.activate ();
	this.hint_displayed <- true;
}")
