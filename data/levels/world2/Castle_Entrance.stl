      (solid #f)
      (name "WATERHINT")
      (sprite "images/objects/keys/key_water.sprite")
      (x 2656)
      (y 96)
    )
    (scripttrigger
      (script "if(state.world2_keys.air) {
	if( ! (\"airopen\" in this)) {
		play_sound(\"sounds/turnkey.ogg\"); // make key sound...
		wait(1);
		AIRHINT.set_action(\"display\");
		wait(2);
		door1.goto_node(1);
		this.airopen <- true;
	}
} else {
	play_sound(\"sounds/locked.ogg\"); 
	// play meep
}")
      (button #f)
      (width 124)
      (height 124)
      (x 672)
      (y 192)
    )
    (scripttrigger
      (script "if(state.world2_keys.earth) {
	if( ! (\"earthopen\" in this)) {
		play_sound(\"sounds/turnkey.ogg\"); // make key sound...
