(supertux-level
  (version 3)
  (name (_ "Entrance to the Castle"))
  (author "Sam Townsend")
  (license "GPL 2")
  (allow-item-pocket "inherit")
  (icon "")
  (icon-locked "")
  (statistics
    (enable-coins #t)
    (enable-secrets #t)
  )
  (sector
    (name "main")
    (init-script "
      AIRHINT.set_action(\"outline\");
      EARTHHINT.set_action(\"outline\");
      FIREHINT.set_action(\"outline\");
      WATERHINT.set_action(\"outline\");
      WOODHINT.set_action(\"outline\");")
    (ambient-light
      (color 1 1 1)
    )
    (background
      (scroll-offset-y -700)
      (color 1 1 1)
      (speed 0.5)
      (image-top "images/background/BlueRock_Forest/blue-top.jpg")
      (image "images/background/BlueRock_Forest/blue-middle.jpg")
      (image-bottom "images/background/BlueRock_Forest/blue-bottom.jpg")
    )
    (camera
      (name "Camera")
      (mode "normal")
    )
    (music
      (file "music/forest3.ogg")
    )
    (path
      (name "gen1772929288104989805356416")
      (path
        (mode "oneshot")
        (adapt_speed #f)
        (node
          (x 800)
          (y 192)
        )
        (node
          (x 800)
          (y 64)
        )
      )
    )
    (path
      (name "gen1772929288104989797397088")
      (path
        (adapt_speed #f)
        (node
          (x 1280)
          (y 192)
        )
        (node
          (x 1280)
          (y 64)
        )
      )
    )
    (path
      (name "gen1772929288104989797396400")
      (path
        (adapt_speed #f)
        (node
          (x 1760)
          (y 192)
        )
        (node
          (x 1760)
          (y 64)
        )
      )
    )
    (path
      (name "gen1772929288104989797396672")
      (path
        (adapt_speed #f)
        (node
          (x 2240)
          (y 192)
        )
        (node
          (x 2240)
          (y 64)
        )
      )
    )
    (path
      (name "gen1772929288104989797412464")
      (path
        (adapt_speed #f)
        (node
          (x 2720)
          (y 192)
        )
        (node
          (x 2720)
          (y 64)
        )
      )
    )
    (platform
      (z-pos 50)
      (handle
        (scale_x 0)
        (scale_y 0)
        (offset_x 0)
        (offset_y 0)
      )
      (running #f)
      (name "door1")
      (path-ref "gen1772929288104989805356416")
      (sprite "images/objects/platforms/vertical-wood.sprite")
    )
    (platform
      (z-pos 50)
      (handle
        (scale_x 0)
        (scale_y 0)
        (offset_x 0)
        (offset_y 0)
      )
      (running #f)
      (name "door2")
      (path-ref "gen1772929288104989797397088")
      (sprite "images/objects/platforms/vertical-wood.sprite")
    )
    (platform
      (z-pos 50)
      (handle
        (scale_x 0)
        (scale_y 0)
        (offset_x 0)
        (offset_y 0)
      )
      (running #f)
      (name "door3")
      (path-ref "gen1772929288104989797396400")
      (sprite "images/objects/platforms/vertical-wood.sprite")
